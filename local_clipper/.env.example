# CustosAI Clipper — Environment Configuration
# Copy this file to .env and fill in your values.

# Whop API v2 — License validation (validate_license endpoint)
# Get your API key from https://whop.com/dashboard/developer
WHOP_API_BASE=https://api.whop.com/api/v2
WHOP_API_KEY=your_whop_api_bearer_token_here

# Admin license (opcional): clave que siempre valida sin llamar a Whop.
# Úsala para tu acceso personal en builds (macOS local, Windows via GitHub Secrets).
# Para Windows CI: añade ADMIN_LICENSE_KEY como secret en Settings → Secrets → Actions.
# ADMIN_LICENSE_KEY=CUSTOS-MASTER-2026-XXXX
